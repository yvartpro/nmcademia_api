DB_NAME=nmacademia_db
DB_USER=root
DB_PASS=
DB_HOST=localhost

# Full public site URL (no trailing slash) — used for media copy URLs and absolute links
# Dev: http://localhost:5000  |  Prod: https://yourdomain.com
SITE_URL=http://localhost:5000

# Optional subdirectory if the app is not at domain root (e.g. /nma)
PUBLIC_BASE_PATH=

# Optional override for upload folder on disk (default: api/uploads)
UPLOADS_DIR=

PORT=5000
